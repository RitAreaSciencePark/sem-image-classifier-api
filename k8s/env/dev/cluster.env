# Tracked infrastructure defaults for dev deployments.
#
# This file may contain only operator-machine values: where the cluster lives,
# which registry receives images, and optional node names for diagnostics.
# Application identity is owned by k8s/dev.sh. Model configuration is owned by
# bentoml-config.yaml or bentoml-config.local.yaml.
K3S_API_HOST=127.0.0.1
K3S_SSH_USER=root
K3S_REMOTE_KUBECONFIG=/etc/rancher/k3s/k3s.yaml
K3S_NODES="127.0.0.1"
REGISTRY=localhost:5000
REGISTRY_SCHEME=http
