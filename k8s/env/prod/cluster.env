# Tracked infrastructure defaults for production deployments.
#
# Replace these through a private deployment process or an ignored local file on
# the operator machine. Keep secrets out of this file.
K3S_API_HOST=prod-k3s.example.org
K3S_SSH_USER=root
K3S_REMOTE_KUBECONFIG=/etc/rancher/k3s/k3s.yaml
K3S_NODES="prod-k3s-control-plane.example.org"
REGISTRY=registry.example.org:5000
REGISTRY_SCHEME=https
