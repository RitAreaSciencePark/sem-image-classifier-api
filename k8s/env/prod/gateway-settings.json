{
  "port": 8080,
  "timeout": "30s",
  "backend_host": "http://bentoml:3000",
  "service_name": "sem-image-classifier",
  "auth": {
    "provider": "authentik",
    "alg": "RS256",
    "jwk_url": "https://auth.example.com/application/o/sem/jwks/",
    "issuer": "https://auth.example.com/application/o/sem/",
    "audience": "sem-image-classifier-api",
    "disable_jwk_security": false,
    "operation_debug": false,
    "authentik": {
      "jwk_url": "https://auth.example.com/application/o/sem/jwks/",
      "issuer": "https://auth.example.com/application/o/sem/",
      "audience": "sem-image-classifier-api",
      "disable_jwk_security": false
    }
  },
  "plugin": {
    "pattern": ".so",
    "folder": "/etc/krakend/plugins",
    "paths": [
      "/api/v1/inference",
      "/api/v1/jobs/status",
      "/api/v1/jobs/results"
    ]
  },
  "database": {
    "host": "postgresql-0.postgresql",
    "port": "5432",
    "user": "krakend",
    "password": "",
    "dbname": "krakend"
  }
}
